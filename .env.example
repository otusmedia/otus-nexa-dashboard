    # Public Supabase (client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public app URL — used in Webflow CRM form snippets (must be production, not localhost)
NEXT_PUBLIC_APP_URL=https://otus-nexa-dashboard.vercel.app

# Server-only — required for /api/crm/submit (load client CRM config + optional audit mirror)
SUPABASE_SERVICE_ROLE_KEY=

# Optional — when set, form body must include turnstileToken from Cloudflare Turnstile
TURNSTILE_SECRET_KEY=

# Optional — translates updates/comments when reader UI language differs from content
OPENAI_API_KEY=
# OPENAI_TRANSLATE_MODEL=gpt-4o-mini

# Go High Level → CRM import (Biotecc / one-time)
GHL_PRIVATE_TOKEN=
GHL_LOCATION_ID=
GHL_CLIENT_SLUG=biotecc
# GHL_PIPELINE_ID=
# GHL_IMPORT_CONTACTS=false
GHL_IMPORT_SECRET=
